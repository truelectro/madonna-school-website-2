<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Next.js Static Export routing
  
  # 1. If the requested file has no extension, check if it exists with an .html extension
  # (This allows URLs like /about to resolve to /about.html)
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ $1.html [L]

  # 2. Prevent 404s for deeper Sanity Studio routes (React SPA fallback)
  # If the URL starts with /admin, serves the /admin/index.html (or whatever next.js named it)
  # Since Next.js generates /admin.html or /admin/index.html depending on routing:
  RewriteCond %{REQUEST_URI} ^/admin
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/admin.html -f
  RewriteRule ^.*$ /admin.html [L]

</IfModule>

# Custom 404 Error Page (if you have one generated by Next.js)
ErrorDocument 404 /404.html
